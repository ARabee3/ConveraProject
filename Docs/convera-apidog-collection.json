{
  "openapi": "3.0.3",
  "info": {
    "title": "Convera API",
    "description": "Comprehensive API documentation for Convera - Infrastructure, Security, and Accommodation domains.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer" },
          "message": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Infrastructure"],
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "System health status",
            "content": {
              "application/json": {
                "example": { "status": "ok", "timestamp": "2026-04-17T17:32:06.023Z" }
              }
            }
          }
        }
      }
    },
    "/hello": {
      "get": {
        "tags": ["Infrastructure"],
        "summary": "Internationalized Hello",
        "parameters": [
          {
            "name": "Accept-Language",
            "in": "header",
            "schema": { "type": "string", "enum": ["en", "ar"], "default": "en" }
          },
          {
            "name": "x-custom-lang",
            "in": "header",
            "schema": { "type": "string", "enum": ["en", "ar"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Translated greeting",
            "content": {
              "text/plain": { "example": "Hello World" }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register User",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "test@example.com" },
                  "password": { "type": "string", "example": "Password123!" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created successfully" }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "code"],
                "properties": {
                  "email": { "type": "string", "example": "test@example.com" },
                  "code": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP verified" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "test@example.com" },
                  "password": { "type": "string", "example": "Password123!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "accessToken": "ey...",
                    "refreshToken": "...",
                    "user": { "id": "uuid", "email": "test@example.com", "role": "CUSTOMER" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Token Refresh",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "refreshToken": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tokens refreshed" }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Forgot Password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "email": { "type": "string", "example": "test@example.com" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent to email" }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset Password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "code": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successful" }
        }
      }
    },
    "/auth/test-rbac": {
      "get": {
        "tags": ["Auth"],
        "summary": "Test Admin Access",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Authorized" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/properties": {
      "get": {
        "tags": ["Properties"],
        "summary": "Search Properties (Public)",
        "parameters": [
          { "name": "lat", "in": "query", "schema": { "type": "number" } },
          { "name": "lng", "in": "query", "schema": { "type": "number" } },
          { "name": "radius", "in": "query", "schema": { "type": "number" } },
          { "name": "priceMin", "in": "query", "schema": { "type": "number" } },
          { "name": "priceMax", "in": "query", "schema": { "type": "number" } },
          { "name": "checkIn", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "checkOut", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "ratingMin", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "List of properties" }
        }
      }
    },
    "/properties/{id}": {
      "get": {
        "tags": ["Properties"],
        "summary": "Property Details (Public)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Full property details" }
        }
      }
    },
    "/host/properties": {
      "get": {
        "tags": ["Host"],
        "summary": "Host: List My Properties",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "List of host properties" }
        }
      },
      "post": {
        "tags": ["Host"],
        "summary": "Host: Create Property",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "type": { "type": "string", "enum": ["APARTMENT", "HOUSE", "VILLA", "STUDIO"] },
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" },
                  "address": { "type": "string" },
                  "amenities": { "type": "array", "items": { "type": "string" } },
                  "imageUrls": { "type": "array", "items": { "type": "string" } },
                  "basePrice": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Property created" }
        }
      }
    },
    "/host/properties/{id}/availability": {
      "post": {
        "tags": ["Host"],
        "summary": "Host: Set Availability/Price Override",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "startDate": { "type": "string", "format": "date" },
                  "endDate": { "type": "string", "format": "date" },
                  "status": { "type": "string", "enum": ["AVAILABLE", "BLOCKED"] },
                  "overridePrice": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Availability updated" }
        }
      }
    },
    "/properties/{propertyId}/reviews": {
      "post": {
        "tags": ["Properties"],
        "summary": "Customer: Submit Review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "propertyId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bookingId": { "type": "string" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Review submitted" }
        }
      }
    }
  }
}
