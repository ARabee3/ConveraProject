generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  HOST
  ADMIN
  SYSTEM_ADMIN
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         Role           @default(CUSTOMER)
  isVerified   Boolean        @default(false)
  isActive     Boolean        @default(true)
  preferredLocale String      @default("en")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  refreshTokens RefreshToken[]
  properties    Property[]
  reviews       Review[]
  bookings      Booking[]
  chatSessions  ChatSession[]
  chatMessages  ChatMessage[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  activityLogs             ActivityLog[] @relation("activityLogs")
  eventRegistrations       EventRegistration[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Accommodation Domain ────────────────────────────────────────────────────

enum PropertyType {
  APARTMENT
  HOTEL
}

enum ListingStatus {
  ACTIVE
  HIDDEN
  REMOVED
}

enum AvailabilityStatus {
  BLOCKED
  PRICE_OVERRIDE
}

model Property {
  id          String       @id @default(uuid())
  hostId      String
  title       String
  description String       @db.Text
  type        PropertyType
  latitude    Float
  longitude   Float
  address     String
  amenities   Json
  imageUrls   Json
  basePrice   Decimal      @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  listingStatus ListingStatus @default(ACTIVE)
  version     Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  host                  User                   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  reviews               Review[]
  availabilityOverrides AvailabilityOverride[]
  bookings              Booking[]
  chatSessions          ChatSession[]

  @@index([hostId])
  @@index([isActive])
  @@index([latitude, longitude])
  @@map("properties")
}

model Review {
  id         String   @id @default(uuid())
  propertyId String
  userId     String
  bookingId  String   @unique
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking    Booking? @relation(fields: [bookingId], references: [id])

  @@unique([userId, propertyId, bookingId])
  @@index([propertyId])
  @@map("reviews")
}

model AvailabilityOverride {
  id            String             @id @default(uuid())
  propertyId    String
  startDate     DateTime
  endDate       DateTime
  status        AvailabilityStatus
  overridePrice Decimal?           @db.Decimal(10, 2)
  createdAt     DateTime           @default(now())

  property      Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([startDate, endDate])
  @@map("availability_overrides")
}

// ─── Event Domain ─────────────────────────────────────────────────────────────

enum EventStatus {
  ACTIVE
  CANCELLED
}

model Event {
  id             String           @id @default(uuid())
  title          String
  description    String           @db.Text
  date           DateTime
  locationLat    Float
  locationLng    Float
  address        String
  price          Decimal          @db.Decimal(10, 2)
  categoryId     String
  status         EventStatus      @default(ACTIVE)
  maxCapacity    Int
  remainingSpots Int
  coverImage     String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  category       EventCategory    @relation(fields: [categoryId], references: [id])
  eligibility    EventEligibility?
  source         EventSource?
  galleryImages  EventGalleryImage[]
  registrations  EventRegistration[]

  @@index([categoryId])
  @@index([date])
  @@index([locationLat, locationLng])
  @@index([status])
  @@map("events")
}

model EventCategory {
  id          String   @id @default(uuid())
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]

  @@map("event_categories")
}

model EventEligibility {
  id                  String   @id @default(uuid())
  eventId             String   @unique
  minAge               Int?
  ticketTypes          Json
  specialRequirements String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_eligibilities")
}

enum EventSourceType {
  EXTERNAL
}

model EventSource {
  id                  String        @id @default(uuid())
  eventId             String        @unique
  sourceType          EventSourceType @default(EXTERNAL)
  externalProviderName String
  externalEventId     String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([externalProviderName, externalEventId])
  @@map("event_sources")
}

model EventGalleryImage {
  id           String   @id @default(uuid())
  eventId      String
  imageUrl     String
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_gallery_images")
}

enum EventRegistrationStatus {
  CONFIRMED
  CANCELLED
}

model EventRegistration {
  id        String                  @id @default(uuid())
  eventId   String
  userId    String
  status    EventRegistrationStatus @default(CONFIRMED)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([userId])
  @@map("event_registrations")
}

// ─── Booking & Financial Engine ───────────────────────────────────────────────

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TransactionStatus {
  INITIATED
  SUCCESS
  FAILED
}

enum PaymentProvider {
  STRIPE
  PAYMOB
}

model Booking {
  id         String        @id @default(uuid())
  propertyId String
  customerId String
  startDate  DateTime
  endDate    DateTime
  totalPrice Decimal       @db.Decimal(10, 2)
  status     BookingStatus @default(PENDING_PAYMENT)
  version    Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer     User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  review       Review?
  chatSession  ChatSession?

  @@index([propertyId])
  @@index([customerId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("bookings")
}

model Transaction {
  id          String          @id @default(uuid())
  bookingId   String
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("EGP")
  provider    PaymentProvider
  providerRef String?
  status      TransactionStatus @default(INITIATED)
  createdAt   DateTime        @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([provider])
  @@map("transactions")
}

// ─── Chat Domain ──────────────────────────────────────────────────────────────

model ChatSession {
  id         String   @id @default(uuid())
  propertyId String
  customerId String
  bookingId  String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  customer   User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  booking    Booking?     @relation(fields: [bookingId], references: [id])
  messages   ChatMessage[]

  @@index([propertyId])
  @@index([customerId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  senderId  String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderId])
  @@map("chat_messages")
}

// ─── Notification Domain ──────────────────────────────────────────────────────

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_MODIFICATION
  BOOKING_CANCELLATION
  EVENT_REMINDER
  CHAT_DIGEST
  ACCOUNT_SUSPENSION
  LISTING_REMOVED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum NotificationCategory {
  REMINDERS
  CHAT_ALERTS
}

model Notification {
  id                String              @id @default(uuid())
  type              NotificationType
  recipientId       String
  channel           NotificationChannel @default(EMAIL)
  status            NotificationStatus  @default(PENDING)
  relatedEntityType String
  relatedEntityId   String
  subject           String?
  retryCount        Int                 @default(0)
  errorMessage      String?             @db.Text
  createdAt         DateTime            @default(now())
  deliveredAt       DateTime?

  recipient User @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  type      NotificationType
  locale    String
  subject   String
  body      String           @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([type, locale])
  @@map("notification_templates")
}

model NotificationPreference {
  id        String               @id @default(uuid())
  userId    String
  category  NotificationCategory
  enabled   Boolean              @default(true)
  updatedAt DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── Admin Domain ─────────────────────────────────────────────────────────────

enum AdminActionType {
  USER_SUSPENDED
  USER_ACTIVATED
  PROPERTY_HIDDEN
  PROPERTY_REMOVED
  PROPERTY_ACTIVATED
  EVENT_UPDATED
}

model ActivityLog {
  id               String          @id @default(uuid())
  actorId          String
  actionType       AdminActionType
  targetEntityType String
  targetEntityId   String
  metadata         Json?
  createdAt        DateTime        @default(now())

  actor User @relation("activityLogs", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([actionType])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Versioned Base Entity (used by locking tests) ────────────────────────────

model BaseEntity {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  @@map("base_entities")
}
