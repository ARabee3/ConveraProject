# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# These map standard localhost ports to your Docker containers
DB_HOST=localhost
DB_PORT=3307
DB_NAME=convera
DB_USER=convera_user
DB_PASSWORD=convera_password
DB_ROOT_PASSWORD=convera_root_password

# Prisma Database URL
DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=convera_redis_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
