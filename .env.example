# Environment Configuration

NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=convera
DB_USER=convera_user
DB_PASSWORD=convera_password
DB_ROOT_PASSWORD=convera_root_password

# Prisma Database URL
DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=convera_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
